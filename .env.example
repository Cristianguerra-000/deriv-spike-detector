# =========================================================
# Laboratorio Deriv - variables de entorno (PLANTILLA)
# Copia este archivo como `.env` y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# =========================================================

# --- Deriv API ---
# Obtén tu token en: https://app.deriv.com/account/api-token
# Permisos recomendados: Read, Trade (solo si vas a operar)
DERIV_API_TOKEN=tu_token_aqui
DERIV_APP_ID=1089
DERIV_WS_URL=wss://ws.derivws.com/websockets/v3

# --- Firebase ---
# Ruta al archivo de credenciales de cuenta de servicio (Firebase Admin SDK)
FIREBASE_CREDENTIALS=./serviceAccountKey.json
FIREBASE_PROJECT_ID=tu-proyecto-firebase

# --- Laboratorio ---
LAB_ENV=development
LAB_LOG_LEVEL=INFO
